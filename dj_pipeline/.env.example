# Pipeline / DataJoint credentials (loaded into the client container via docker-compose env_file).
# DJ_HOST port must match DB_PORT in .env.compose when using the local Docker database.
DJ_HOST=your-db-hostname-or-ip:3306
DJ_USER=your-db-user
DJ_PWD=your-db-password
DJ_LAB=mathis-lab
GUI=True
DJ_SUPPORT_FILEPATH_MANAGEMENT=TRUE
DJ_SUPPORT_ADAPTED_TYPES=TRUE

# Summary plot emails (cron / run.py summary). Set EMAIL_SINCE when enabling EMAIL=true
# so only new sessions are emailed (YYYY-MM-DD); leave unset to skip auto-email.
EMAIL=false
VR4MICE_EMAIL_RECIPIENTS=mathislab
VR4MICE_EMAIL_SINCE=2026-07-01
