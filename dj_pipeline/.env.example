DJ_HOST=your-db-hostname-or-ip:3306
DJ_USER=your-db-user
DJ_PWD=your-db-password
DJ_LAB=mathis-lab
GUI=True
DJ_SUPPORT_FILEPATH_MANAGEMENT=TRUE
DJ_SUPPORT_ADAPTED_TYPES=TRUE

# Docker-compose overrides (optional)
# Use a unique COMPOSE_PROJECT (+ container names + DB_PORT) per deployment on the same server.
COMPOSE_PROJECT=vr4mice
DB_BIND_IP=0.0.0.0
DB_PORT=3309
MYSQL_ROOT_PASSWORD=simple
DB_DATA_PATH=/mnt/database/vr4mice/vr4mice_database/database/
SHARED_PATH=/mnt/database/shared
DATA_PATH=/mnt/database/vr4mice/vr4mice_database/data
SCREEN_RECORDINGS_PATH=/mnt/neuropixel_data/vr4mice/raw_screen_recordings
JUPYTER_PORT=8887
CLIENT_IMAGE=mmathislab/vr4mice_app:0.1.0
CLIENT_CONTAINER_NAME=vr4mice_${USER}
DB_CONTAINER_NAME=vr4mice_db
CLIENT_NETWORK_MODE=host
