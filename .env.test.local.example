# Test configuration for scene project
# Copy this file to .env.test.local and customize for your environment
# The .env.test.local file is loaded by tests/conftest.py before running tests

# ==============================================================================
# RAW_ROOT_DATA_DIR: Where to find golden test data
# ==============================================================================
# Expected structure: {RAW_ROOT_DATA_DIR}/golden_dataset/
#   containing: Nightingale_2024-08-16_1.pickle, .json, _DLC.hdf5, _TS.npy, _PROC
#
# Examples:
#   Windows with WSL: /mnt/c/Users/yourname/data/scene_test_data
#   Linux/Mac: /data/scene/test_data
#   Relative to project: ../test_data (resolved from scene/ directory)
#
# If not set, falls back to system temp directory (integration tests will skip)
RAW_ROOT_DATA_DIR=

# ==============================================================================
# Database Configuration
# ==============================================================================
# Prefix for test databases (all test schemas use this prefix)
DATABASE_PREFIX=test_scene_

# ==============================================================================
# External MySQL Support (optional)
# ==============================================================================
# By default, database tests use testcontainers to start MySQL automatically.
# If you have Docker issues (e.g., WSL, CI environments), you can use an
# external MySQL instance instead.
#
# To use external MySQL:
# 1. Start MySQL (e.g., via docker-compose or an existing server)
# 2. Set DJ_USE_EXTERNAL_CONTAINERS=1
# 3. Configure connection settings below
#
# DJ_USE_EXTERNAL_CONTAINERS=1
# DJ_HOST=localhost
# DJ_PORT=3306
# DJ_USER=root
# DJ_PASSWORD=simple
#
# Example with docker-compose already running:
#   DJ_USE_EXTERNAL_CONTAINERS=1
#   DJ_HOST=127.0.0.1
#   DJ_PORT=3306
